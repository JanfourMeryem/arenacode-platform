# ═══════════════════════════════════════════════════════════
# AlgoArena — Environment variables
# Copy to .env and adjust as needed.
# ═══════════════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# CORS — set to your domain in production
CORS_ORIGIN=https://platform.mehditmimi.com

# Execution limits
EXEC_TIMEOUT=30000
MAX_OUTPUT=65536
MAX_FILES=20

# Rate limiting
RATE_WINDOW_MS=60000
RATE_MAX_REQ=30

# WebSocket
WS_MAX_CONNECTIONS=50

# Docker Compose
HTTP_PORT=80
